---
import '../styles/global.css';

interface Props {
	title?: string;
	pageTitle?: string;
	currentPath?: string;
}

const { title = "CSMP Admin", pageTitle = "Overview Dashboard", currentPath = "/" } = Astro.props;
---

<!DOCTYPE html>
<html class="light" lang="en">
<head>
	<meta charset="utf-8"/>
	<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
	<title>{title}</title>
	<!-- Google Fonts -->
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&amp;family=JetBrains+Mono&amp;display=swap" rel="stylesheet"/>
	<!-- Material Symbols -->
	<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
</head>
<body class="flex min-h-screen text-on-surface">
	<!-- SIDE BAR NAVIGATION -->
	<aside class="w-[260px] h-screen fixed left-0 top-0 bg-primary border-r border-outline-variant/10 flex flex-col py-lg z-50">
		<!-- Brand Header -->
		<div class="px-lg mb-xl">
			<div class="flex items-center gap-3">
				<div class="w-10 h-10 bg-secondary-fixed rounded flex items-center justify-center">
					<span class="material-symbols-outlined text-primary font-bold">account_balance</span>
				</div>
				<div>
					<h1 class="font-headline-md text-headline-md text-on-primary">CSMP</h1>
					<p class="font-label-caps text-label-caps text-on-primary/60 tracking-widest uppercase">Institutional Finance</p>
				</div>
			</div>
		</div>

		<!-- Nav Items -->
		<nav class="flex-1 px-sm space-y-1 overflow-y-auto custom-scrollbar">
			<a class={`flex items-center gap-3 px-4 py-3 transition-all duration-200 active:scale-95 group ${currentPath === '/' ? 'border-l-4 border-secondary-fixed bg-white/10 text-on-primary font-bold' : 'text-on-primary/70 hover:text-on-primary hover:bg-white/5'}`} href="/">
				<span class={`material-symbols-outlined ${currentPath === '/' ? 'text-secondary-fixed' : ''}`}>dashboard</span>
				<span class="font-title-sm text-title-sm">Dashboard</span>
			</a>
			<a class={`flex items-center gap-3 px-4 py-3 transition-all duration-200 active:scale-95 group ${currentPath === '/pool-management' ? 'border-l-4 border-secondary-fixed bg-white/10 text-on-primary font-bold' : 'text-on-primary/70 hover:text-on-primary hover:bg-white/5'}`} href="/pool-management">
				<span class={`material-symbols-outlined ${currentPath === '/pool-management' ? 'text-secondary-fixed' : ''}`}>account_balance</span>
				<span class="font-title-sm text-title-sm">Pool Management</span>
			</a>
			<a class={`flex items-center gap-3 px-4 py-3 transition-all duration-200 active:scale-95 group ${currentPath === '/user-directory' ? 'border-l-4 border-secondary-fixed bg-white/10 text-on-primary font-bold' : 'text-on-primary/70 hover:text-on-primary hover:bg-white/5'}`} href="/user-directory">
				<span class={`material-symbols-outlined ${currentPath === '/user-directory' ? 'text-secondary-fixed' : ''}`}>group</span>
				<span class="font-title-sm text-title-sm">User Directory</span>
			</a>
			<a class="flex items-center gap-3 px-4 py-3 text-on-primary/70 hover:text-on-primary hover:bg-white/5 transition-all duration-200 active:scale-95 group" href="#">
				<span class="material-symbols-outlined">settings</span>
				<span class="font-title-sm text-title-sm">Settings</span>
			</a>
		</nav>

		<!-- Footer Profile Info -->
		<div class="mt-auto px-lg pt-lg border-t border-white/10">
			<div class="flex items-center gap-3">
				<div class="w-8 h-8 rounded-full overflow-hidden bg-primary-container">
					<img class="w-full h-full object-cover" alt="Admin user" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA-NOaWn9RiFaIGTCJwngpn6EB5L5mg_UtO5393KYH31eFYUHtzyBOPRGWTw8ZuUFiRcT-yB5pWqBwf-2IPKPuiNAELBL1UY69gvFt1daO04w8zMpi5SajzI570NmRiwFVh_cuCiVahNa2ZxUtjsl8by-4ogzpWLYhjafSvEO4NhnFpOirR9b3gx9EEwysHReWfIuszcen5Ob8WeeXz93UaeQhG021Otq6UVDa6gu-i_t0HxpFSJYIc"/>
				</div>
				<div class="flex-1 min-w-0">
					<p class="text-on-primary font-title-sm text-[13px] truncate">Admin User</p>
					<p class="text-on-primary/50 text-[11px] truncate">Super Administrator</p>
				</div>
			</div>
		</div>
	</aside>

	<!-- MAIN CONTENT AREA -->
	<main class="ml-[260px] flex-1 flex flex-col min-w-0">
		<!-- TOP APP BAR -->
		<header class="flex justify-between items-center h-16 px-gutter w-full sticky top-0 bg-surface border-b border-surface-container-highest shadow-sm z-40">
			<div class="flex items-center gap-6">
				<h2 class="font-headline-md text-headline-md text-primary font-extrabold tracking-tight">{pageTitle}</h2>
				<!-- Search Bar -->
				<div class="hidden md:flex items-center bg-surface-container-low border border-outline-variant/30 rounded-lg px-3 py-1.5 w-72 transition-all focus-within:border-primary focus-within:ring-2 focus-within:ring-primary/10">
					<span class="material-symbols-outlined text-on-surface-variant text-[20px]">search</span>
					<input class="bg-transparent border-none focus:ring-0 text-body-md w-full placeholder:text-on-surface-variant/60 outline-none" placeholder="Search protocol data..." type="text"/>
				</div>
			</div>
			<div class="flex items-center gap-4">
				<button class="w-10 h-10 flex items-center justify-center text-on-surface-variant hover:bg-surface-container-low rounded-full transition-colors active:opacity-80">
					<span class="material-symbols-outlined">notifications</span>
				</button>
				<button class="w-10 h-10 flex items-center justify-center text-on-surface-variant hover:bg-surface-container-low rounded-full transition-colors active:opacity-80">
					<span class="material-symbols-outlined">help_outline</span>
				</button>
				<div class="h-8 w-[1px] bg-outline-variant/30 mx-1"></div>
				<div class="flex items-center gap-2 px-2 py-1 rounded-lg hover:bg-surface-container-low cursor-pointer transition-colors">
					<div class="w-8 h-8 rounded-full bg-secondary-container/20 flex items-center justify-center">
						<span class="material-symbols-outlined text-secondary text-[20px]">account_circle</span>
					</div>
					<span class="material-symbols-outlined text-on-surface-variant">expand_more</span>
				</div>
			</div>
		</header>

		<!-- DASHBOARD CANVAS / SLOT -->
		<div class="p-gutter space-y-gutter overflow-y-auto">
			<slot />
		</div>
	</main>
</body>
</html>
