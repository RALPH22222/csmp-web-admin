---
import Layout from "./Layout.astro";

interface Props {
	title?: string;
	pageTitle?: string;
	currentPath?: string;
}

const { title = "CSMP Admin", pageTitle = "Overview Dashboard" } = Astro.props;
const currentPath = Astro.props.currentPath || Astro.url.pathname;

let userEmail = "Admin User";
try {
	const accessToken = Astro.cookies.get("sb-access-token")?.value;
	if (accessToken) {
		// We can optionally decode JWT or fetch from supabase
		// For simplicity, we can use the supabase client to get the user
		const { createClient } = await import("@supabase/supabase-js");
		const sb = createClient(
			import.meta.env.PUBLIC_SUPABASE_URL,
			import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
		);
		const { data } = await sb.auth.getUser(accessToken);
		if (data?.user?.email) {
			userEmail = data.user.email;
		}
	}
} catch (e) {
	console.error("Failed to parse user session", e);
}
---

<Layout title={title} bodyClass="flex min-h-screen text-on-surface">
	<Fragment slot="head">
		<slot name="head" />
	</Fragment>
	<!-- SIDE BAR NAVIGATION -->
	<aside
		class="w-[260px] h-screen fixed left-0 top-0 bg-primary border-r border-outline-variant/10 flex flex-col py-lg z-50"
	>
		<!-- Brand Header -->
		<div class="px-lg mb-xl">
			<div class="flex items-center gap-3">
				<div
					class="w-10 h-10 bg-secondary-fixed rounded flex items-center justify-center"
				>
					<span
						class="material-symbols-outlined text-primary font-bold"
						>account_balance</span
					>
				</div>
				<div>
					<h1
						class="font-headline-md text-headline-md text-on-primary"
					>
						CSMP
					</h1>
					<p
						class="font-label-caps text-label-caps text-on-primary/60 tracking-widest uppercase"
					>
						Institutional Finance
					</p>
				</div>
			</div>
		</div>

		<!-- Nav Items -->
		<nav class="flex-1 px-sm space-y-1 overflow-y-auto custom-scrollbar">
			<a
				class={`flex items-center gap-3 px-4 py-3 transition-all duration-200 active:scale-95 group ${currentPath === "/" ? "border-l-4 border-secondary-fixed bg-white/10 text-on-primary font-bold" : "text-on-primary/70 hover:text-on-primary hover:bg-white/5"}`}
				href="/"
			>
				<span
					class={`material-symbols-outlined ${currentPath === "/" ? "text-secondary-fixed" : ""}`}
					>dashboard</span
				>
				<span class="font-title-sm text-title-sm">Dashboard</span>
			</a>
			<a
				class={`flex items-center gap-3 px-4 py-3 transition-all duration-200 active:scale-95 group ${currentPath === "/pool-management" ? "border-l-4 border-secondary-fixed bg-white/10 text-on-primary font-bold" : "text-on-primary/70 hover:text-on-primary hover:bg-white/5"}`}
				href="/pool-management"
			>
				<span
					class={`material-symbols-outlined ${currentPath === "/pool-management" ? "text-secondary-fixed" : ""}`}
					>account_balance</span
				>
				<span class="font-title-sm text-title-sm">Pool Management</span>
			</a>
			<a
				class={`flex items-center gap-3 px-4 py-3 transition-all duration-200 active:scale-95 group ${currentPath === "/user-directory" ? "border-l-4 border-secondary-fixed bg-white/10 text-on-primary font-bold" : "text-on-primary/70 hover:text-on-primary hover:bg-white/5"}`}
				href="/user-directory"
			>
				<span
					class={`material-symbols-outlined ${currentPath === "/user-directory" ? "text-secondary-fixed" : ""}`}
					>group</span
				>
				<span class="font-title-sm text-title-sm">User Directory</span>
			</a>
		</nav>

		<!-- Footer Profile Info -->
		<div class="mt-auto px-lg pt-lg border-t border-white/10 pb-4">
			<div class="flex items-center gap-3">
				<div class="flex-1 min-w-0">
					<p
						class="text-on-primary font-title-sm text-[13px] truncate"
					>
						{userEmail}
					</p>
					<p class="text-on-primary/50 text-[11px] truncate">
						Administrator
					</p>
				</div>
				<a
					href="/api/auth/logout"
					class="text-on-primary/50 hover:text-white transition-colors"
					title="Logout"
				>
					<span class="material-symbols-outlined text-[20px]"
						>logout</span
					>
				</a>
			</div>
		</div>
	</aside>

	<!-- MAIN CONTENT AREA -->
	<main class="ml-[260px] flex-1 flex flex-col min-w-0">
		<!-- TOP APP BAR -->
		<header
			class="flex justify-between items-center h-16 px-gutter w-full sticky top-0 bg-surface border-b border-surface-container-highest shadow-sm z-40"
		>
			<div class="flex items-center gap-6">
				<h2
					class="font-headline-md text-headline-md text-primary font-extrabold tracking-tight"
				>
					{pageTitle}
				</h2>
				<!-- Search Bar -->
				<div
					class="hidden md:flex items-center bg-surface-container-low border border-outline-variant/30 rounded-lg px-3 py-1.5 w-72 transition-all focus-within:border-primary focus-within:ring-2 focus-within:ring-primary/10"
				>
					<span
						class="material-symbols-outlined text-on-surface-variant text-[20px]"
						>search</span
					>
					<input
						class="bg-transparent border-none focus:ring-0 text-body-md w-full placeholder:text-on-surface-variant/60 outline-none"
						placeholder="Search protocol data..."
						type="text"
					/>
				</div>
			</div>
			<div class="flex items-center gap-4">
				<button
					class="w-10 h-10 flex items-center justify-center text-on-surface-variant hover:bg-surface-container-low rounded-full transition-colors active:opacity-80"
				>
					<span class="material-symbols-outlined">notifications</span>
				</button>
				<button
					class="w-10 h-10 flex items-center justify-center text-on-surface-variant hover:bg-surface-container-low rounded-full transition-colors active:opacity-80"
				>
					<span class="material-symbols-outlined">help_outline</span>
				</button>
			</div>
		</header>

		<!-- DASHBOARD CANVAS / SLOT -->
		<div class="p-gutter space-y-gutter overflow-y-auto">
			<slot />
		</div>
	</main>
</Layout>
