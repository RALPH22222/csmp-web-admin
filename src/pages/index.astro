---
import AdminLayout from "../layouts/AdminLayout.astro";
import { getDashboardStats } from "../server/services/dashboardService";

let activePoolsCount = 0;
let totalTVL = 0;
let usersCount = 0;
let recentActivity: any[] = [];
let userAddresses: string[] = [];

// Future backend variables to wire up
let liquidityScore = 0;
let pendingPoolsCount = 0;
let verifiedAgentsCount = 0;
let monthlyDisbursements = 0;

try {
  const stats = await getDashboardStats();
  activePoolsCount = stats.activePoolsCount;
  totalTVL = stats.totalTVL;
  usersCount = stats.usersCount;
  recentActivity = stats.recentActivity;
  userAddresses = stats.addresses || [];
  
  liquidityScore = stats.liquidityScore;
  pendingPoolsCount = stats.pendingPoolsCount;
  verifiedAgentsCount = stats.verifiedAgentsCount;
  monthlyDisbursements = stats.monthlyDisbursements;
} catch (e) {
  console.error("Failed to fetch dashboard stats", e);
}

const formattedTVL = new Intl.NumberFormat("en-PH", {
  style: "currency",
  currency: "PHP",
}).format(totalTVL);
---

<AdminLayout
  title="CSMP - Overview Dashboard"
  pageTitle="Overview Dashboard"
  currentPath="/"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin=""/>
    <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
  </Fragment>

  <!-- METRIC CARDS -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter">
    <!-- TVL Card -->
    <div
      class="bg-white p-lg border border-outline-variant/30 shadow-[0px_2px_4px_rgba(0,0,0,0.05)] rounded-xl group hover:scale-[1.01] transition-transform duration-200"
    >
      <div class="flex justify-between items-start mb-4">
        <span
          class="material-symbols-outlined text-primary-container p-2 bg-primary-fixed rounded-lg"
          >payments</span
        >
        <span class="text-secondary text-sm font-bold flex items-center"
          >+4.2% <span class="material-symbols-outlined text-xs"
            >arrow_upward</span
          ></span
        >
      </div>
      <p
        class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider mb-1"
      >
        Total Value Locked
      </p>
      <h3 class="font-display-lg text-display-lg text-primary tracking-tight">
        {formattedTVL}
      </h3>
    </div>
    <!-- Active Pools Card -->
    <div
      class="bg-white p-lg border border-outline-variant/30 shadow-[0px_2px_4px_rgba(0,0,0,0.05)] rounded-xl group hover:scale-[1.01] transition-transform duration-200"
    >
      <div class="flex justify-between items-start mb-4">
        <span
          class="material-symbols-outlined text-primary-container p-2 bg-primary-fixed rounded-lg"
          >account_balance_wallet</span
        >
        <span class="text-on-surface-variant text-sm font-bold">Stable</span>
      </div>
      <p
        class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider mb-1"
      >
        Active Pools
      </p>
      <h3 class="font-display-lg text-display-lg text-primary tracking-tight">
        {activePoolsCount}
      </h3>
    </div>
    <!-- Total Users Card -->
    <div
      class="bg-white p-lg border border-outline-variant/30 shadow-[0px_2px_4px_rgba(0,0,0,0.05)] rounded-xl group hover:scale-[1.01] transition-transform duration-200"
    >
      <div class="flex justify-between items-start mb-4">
        <span
          class="material-symbols-outlined text-primary-container p-2 bg-primary-fixed rounded-lg"
          >group</span
        >
        <span class="text-secondary text-sm font-bold flex items-center"
          >+12 <span class="material-symbols-outlined text-xs">person_add</span
          ></span
        >
      </div>
      <p
        class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider mb-1"
      >
        Total Users
      </p>
      <h3 class="font-display-lg text-display-lg text-primary tracking-tight">
        {usersCount || 0}
      </h3>
    </div>
    <!-- Default Rate Card -->
    <div
      class="bg-white p-lg border border-outline-variant/30 shadow-[0px_2px_4px_rgba(0,0,0,0.05)] rounded-xl group hover:scale-[1.01] transition-transform duration-200"
    >
      <div class="flex justify-between items-start mb-4">
        <span
          class="material-symbols-outlined text-primary-container p-2 bg-primary-fixed rounded-lg"
          >monitoring</span
        >
        <span class="text-error text-sm font-bold flex items-center"
          >-0.3% <span class="material-symbols-outlined text-xs"
            >arrow_downward</span
          ></span
        >
      </div>
      <p
        class="font-label-caps text-label-caps text-on-surface-variant uppercase tracking-wider mb-1"
      >
        Default Rate
      </p>
      <h3
        class="font-display-lg text-display-lg text-secondary-container tracking-tight"
        style="color: #69ff87;"
      >
        1.2%
      </h3>
    </div>
  </div>

  <!-- MAIN GRID SECTION -->
  <div class="grid grid-cols-12 gap-gutter">
    <!-- ACTIVITY TABLE (Left 8 Columns) -->
    <div
      class="col-span-12 lg:col-span-8 bg-white border border-outline-variant/30 shadow-[0px_2px_4px_rgba(0,0,0,0.05)] rounded-xl overflow-hidden flex flex-col"
    >
      <div
        class="px-lg py-4 border-b border-surface-container-highest flex justify-between items-center bg-surface-container-low"
      >
        <h4 class="font-headline-md text-headline-md text-primary">
          Recent Activity
        </h4>
        <a href="/logs" class="text-primary text-sm font-bold hover:underline"
          >View All Report</a
        >
      </div>
      <div class="w-full">
        <table class="w-full table-fixed text-left border-collapse">
          <thead>
            <tr class="bg-surface-container-lowest">
              <th
                class="px-lg py-3 font-label-caps text-label-caps text-on-surface-variant border-b border-surface-container-highest"
                >Activity Type</th
              >
              <th
                class="px-lg py-3 font-label-caps text-label-caps text-on-surface-variant border-b border-surface-container-highest"
                >Pool Name</th
              >
              <th
                class="px-lg py-3 font-label-caps text-label-caps text-on-surface-variant border-b border-surface-container-highest"
                >Amount</th
              >
              <th
                class="px-lg py-3 font-label-caps text-label-caps text-on-surface-variant border-b border-surface-container-highest"
                >Date</th
              >
              <th
                class="px-lg py-3 font-label-caps text-label-caps text-on-surface-variant border-b border-surface-container-highest"
                >Status</th
              >
            </tr>
          </thead>
          <tbody class="divide-y divide-surface-container-highest">
            {
              recentActivity && recentActivity.length > 0 ? (
                recentActivity.map((activity) => (
                  <tr class="hover:bg-[#F0F4F3] transition-colors group">
                    <td class="px-lg py-4">
                      <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-secondary text-[18px]">
                          {(activity.transaction_types as any)?.type_name
                            ?.toLowerCase()
                            .includes("payout")
                            ? "outbox"
                            : "account_balance"}
                        </span>
                        <span class="text-body-md font-medium text-on-surface">
                          {(activity.transaction_types as any)?.type_name ||
                            "Transaction"}
                        </span>
                      </div>
                    </td>
                    <td class="px-lg py-4 text-body-md text-on-surface-variant">
                      {(activity.pool_members as any)?.pools?.pool_name ||
                        "Unknown Pool"}
                    </td>
                    <td class="px-lg py-4 font-code-mono text-primary font-bold">
                      {new Intl.NumberFormat("en-PH", {
                        style: "currency",
                        currency: "PHP",
                      }).format(activity.amount)}
                    </td>
                    <td class="px-lg py-4 text-body-sm text-on-surface-variant">
                      {new Date(activity.executed_at).toLocaleDateString(
                        "en-US",
                        { month: "short", day: "numeric", year: "numeric" },
                      )}
                    </td>
                    <td class="px-lg py-4">
                      <span
                        class={`px-2 py-1 text-[11px] font-bold rounded-full uppercase tracking-tighter ${
                          (
                            activity.transaction_statuses as any
                          )?.status_name?.toLowerCase() === "completed"
                            ? "bg-secondary-container/15 text-on-secondary-container"
                            : "bg-tertiary-container/15 text-on-tertiary-container"
                        }`}
                      >
                        {(activity.transaction_statuses as any)?.status_name ||
                          "Processing"}
                      </span>
                    </td>
                  </tr>
                ))
              ) : (
                <tr>
                  <td
                    colspan="5"
                    class="px-lg py-8 text-center text-on-surface-variant"
                  >
                    No recent activity found.
                  </td>
                </tr>
              )
            }
          </tbody>
        </table>
      </div>
    </div>
    <!-- RIGHT PANEL: ASYMMETRIC VISUAL (Right 4 Columns) -->
    <div class="col-span-12 lg:col-span-4 space-y-gutter">
      <!-- Protocol Performance Visualization -->
      <div
        class="bg-primary rounded-xl p-lg text-on-primary h-64 relative overflow-hidden group"
      >
        <div class="absolute inset-0 opacity-20 pointer-events-none"></div>
        <div class="relative z-10 h-full flex flex-col justify-between">
          <div>
            <h4 class="font-headline-md text-headline-md mb-2">
              Protocol Health
            </h4>
            <p class="text-on-primary/60 text-body-md max-w-[200px]">
              Real-time audit of liquidity pools and disbursement safety.
            </p>
          </div>
          <div class="space-y-4">
            <div class="w-full bg-white/10 h-2 rounded-full overflow-hidden">
              <div
                class="bg-secondary-fixed h-full w-[88%] rounded-full shadow-[0_0_8px_rgba(105,255,135,0.5)]"
              >
              </div>
            </div>
            <div class="flex justify-between items-center text-label-caps">
              <span>LIQUIDITY SCORE</span>
              <span class="text-secondary-fixed font-bold">{liquidityScore}/100</span>
            </div>
          </div>
        </div>
      </div>
      <!-- Map/Location Context -->
      <div
        class="bg-white border border-outline-variant/30 shadow-[0px_2px_4px_rgba(0,0,0,0.05)] rounded-xl p-lg"
      >
        <div class="flex items-center justify-between mb-4">
          <h4 class="font-title-sm text-title-sm text-primary">
            Active Disbursement Areas
          </h4>
          <span class="material-symbols-outlined text-on-surface-variant"
            >location_on</span
          >
        </div>
        <div class="relative w-full h-[280px] rounded-lg overflow-hidden border border-outline-variant/20">
          <div id="philippines-map" class="w-full h-full z-10"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- BENTO STYLE CARDS BOTTOM SECTION -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
    <div
      class="bg-white p-lg border border-outline-variant/30 shadow-[0px_2px_4px_rgba(0,0,0,0.05)] rounded-xl flex items-center gap-4"
    >
      <div
        class="w-12 h-12 rounded bg-tertiary/10 flex items-center justify-center"
      >
        <span class="material-symbols-outlined text-tertiary">warning</span>
      </div>
      <div>
        <p class="font-label-caps text-label-caps text-on-surface-variant uppercase">
          Pending Reviews
        </p>
        <h4 class="font-headline-md text-headline-md text-primary">{pendingPoolsCount} Pools</h4>
      </div>
    </div>
    <div
      class="bg-white p-lg border border-outline-variant/30 shadow-[0px_2px_4px_rgba(0,0,0,0.05)] rounded-xl flex items-center gap-4"
    >
      <div
        class="w-12 h-12 rounded bg-secondary/10 flex items-center justify-center"
      >
        <span class="material-symbols-outlined text-secondary"
          >verified_user</span
        >
      </div>
      <div>
        <p class="font-label-caps text-label-caps text-on-surface-variant uppercase">
          Verified Agents
        </p>
        <h4 class="font-headline-md text-headline-md text-primary">
          {verifiedAgentsCount} Agents
        </h4>
      </div>
    </div>
    <div
      class="bg-white p-lg border border-outline-variant/30 shadow-[0px_2px_4px_rgba(0,0,0,0.05)] rounded-xl flex items-center gap-4"
    >
      <div
        class="w-12 h-12 rounded bg-primary/10 flex items-center justify-center"
      >
        <span class="material-symbols-outlined text-primary">receipt_long</span>
      </div>
      <div>
        <p class="font-label-caps text-label-caps text-on-surface-variant uppercase">
          Month Disbursements
        </p>
        <h4 class="font-headline-md text-headline-md text-primary">₱ {monthlyDisbursements.toLocaleString()}</h4>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ userAddresses }}>
    // Micro-interactions for table rows
    document.querySelectorAll("tbody tr").forEach((row) => {
      row.addEventListener("mouseenter", () => {
        row.style.transform = "translateX(4px)";
        row.style.transition = "transform 0.2s ease-out";
      });
      row.addEventListener("mouseleave", () => {
        row.style.transform = "translateX(0)";
      });
    });

    // Leaflet Map Initialization
    if (typeof L !== 'undefined') {
      const map = L.map('philippines-map', {
        zoomControl: false,
        attributionControl: false
      }).setView([12.8797, 121.7740], 5); // Center on Philippines

      // Dark mode map tiles
      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        subdomains: 'abcd',
        maxZoom: 20
      }).addTo(map);

      // Disable dragging and zooming for a static dashboard aesthetic
      map.dragging.disable();
      map.touchZoom.disable();
      map.doubleClickZoom.disable();
      map.scrollWheelZoom.disable();
      map.boxZoom.disable();
      map.keyboard.disable();

      // Dictionary to map address string matches to coordinates
      const cityCoords = {
        'manila': [14.5995, 120.9842],
        'cebu': [10.3157, 123.8854],
        'davao': [7.1907, 125.4553],
        'quezon': [14.6760, 121.0437],
        'makati': [14.5547, 121.0244],
        'taguig': [14.5176, 121.0509],
        'pasig': [14.5764, 121.0851],
        'zamboanga': [6.9214, 122.0790],
        'cagayan de oro': [8.4542, 124.6319],
        'iloilo': [10.7202, 122.5621],
        'bacolod': [10.6650, 122.9498]
      };

      // Distinct colors for different users
      const colors = ['#69FF87', '#FF69B4', '#00BFFF', '#FFD700', '#FF6347', '#DDA0DD', '#00FA9A', '#FF4500'];

      // Plot dynamic addresses
      userAddresses.forEach((address, index) => {
        const addrLower = address.toLowerCase();
        let coords = [12.8797, 121.7740]; // Default PH center
        
        // Find if address matches a known city
        for (const [city, cityCoord] of Object.entries(cityCoords)) {
          if (addrLower.includes(city)) {
            coords = [...cityCoord];
            break;
          }
        }
        
        // Randomize slightly so markers don't overlap completely
        const offsetLat = (Math.random() - 0.5) * 0.1;
        const offsetLng = (Math.random() - 0.5) * 0.1;
        
        const color = colors[index % colors.length];
        const dynamicIcon = L.divIcon({
          className: '',
          html: `<div style="width: 12px; height: 12px; background-color: ${color}; border-radius: 50%; box-shadow: 0 0 10px ${color}, 0 0 20px ${color}; opacity: 0.9;"></div>`,
          iconSize: [12, 12],
          iconAnchor: [6, 6]
        });

        L.marker([coords[0] + offsetLat, coords[1] + offsetLng], { icon: dynamicIcon })
          .bindPopup(`<b>Registered Citizen</b><br/>${address}`)
          .addTo(map);
      });

      // Force Leaflet to recalculate the container size to prevent gray/missing tiles
      setTimeout(() => {
        map.invalidateSize();
      }, 250);
    }
  </script>
</AdminLayout>
