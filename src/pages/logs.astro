---
import AdminLayout from "../layouts/AdminLayout.astro";
import { supabaseAdmin } from "../server/supabase";

const { data: transactions, error } = await supabaseAdmin
  .from('transactions')
  .select(`
    id,
    amount,
    executed_at,
    transaction_types ( type_name ),
    transaction_statuses ( status_name ),
    pool_members ( pools ( pool_name ) )
  `)
  .order('executed_at', { ascending: false })
  .limit(100);

const realLogs = (transactions || []).map(tx => {
  const typeName = (tx.transaction_types as any)?.type_name || 'Transaction';
  const statusName = (tx.transaction_statuses as any)?.status_name || 'Processing';
  const poolName = (tx.pool_members as any)?.pools?.pool_name || 'Unknown Pool';
  
  let type = 'INFO';
  let message = `${typeName} of ₱${tx.amount || 0} processed in ${poolName}. Status: ${statusName}`;

  if (statusName.toLowerCase() === 'failed' || statusName.toLowerCase() === 'rejected') {
    type = 'ERROR';
    message = `Failed ${typeName.toLowerCase()} in ${poolName}.`;
  } else if (statusName.toLowerCase() === 'pending' || statusName.toLowerCase() === 'processing') {
    type = 'WARNING';
    message = `Pending ${typeName.toLowerCase()} in ${poolName} needs review.`;
  }

  return {
    id: tx.id,
    type,
    message,
    timestamp: new Date(tx.executed_at).toLocaleString()
  };
});
---

<AdminLayout title="CSMP - Logs" pageTitle="System Logs" currentPath="/logs">
  <div class="bg-white border border-outline-variant/30 shadow-[0px_2px_4px_rgba(0,0,0,0.05)] rounded-xl overflow-hidden flex flex-col">
    <div class="px-lg py-4 border-b border-surface-container-highest flex justify-between items-center bg-surface-container-low">
      <h4 class="font-headline-md text-headline-md text-primary">System Logs</h4>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-surface-container-lowest">
            <th class="px-lg py-3 font-label-caps text-label-caps text-on-surface-variant border-b border-surface-container-highest">Time</th>
            <th class="px-lg py-3 font-label-caps text-label-caps text-on-surface-variant border-b border-surface-container-highest">Type</th>
            <th class="px-lg py-3 font-label-caps text-label-caps text-on-surface-variant border-b border-surface-container-highest">Message</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-surface-container-highest">
          {realLogs.length > 0 ? (
            realLogs.map(log => (
              <tr class="hover:bg-[#F0F4F3] transition-colors group">
                <td class="px-lg py-4 text-body-sm text-on-surface-variant">{log.timestamp}</td>
                <td class="px-lg py-4">
                  <span class={`px-2 py-1 text-[11px] font-bold rounded-full uppercase tracking-tighter ${
                    log.type === 'INFO' ? 'bg-secondary-container/15 text-on-secondary-container' :
                    log.type === 'WARNING' ? 'bg-[#FFF3E0] text-[#E65100]' :
                    'bg-error-container/15 text-on-error-container'
                  }`}>
                    {log.type}
                  </span>
                </td>
                <td class="px-lg py-4 text-body-md text-on-surface font-medium">{log.message}</td>
              </tr>
            ))
          ) : (
            <tr>
              <td colspan="3" class="px-lg py-8 text-center text-on-surface-variant">
                No system logs found. The transactions table is currently empty.
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>
</AdminLayout>
