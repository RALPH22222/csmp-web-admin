---
import AdminLayout from "../layouts/AdminLayout.astro";
import { getAdminPools } from "../server/services/poolService";

let institutionalPools: any[] = [];
let citizenPools: any[] = [];
let allPools: any[] = [];

try {
  const data = await getAdminPools();
  institutionalPools = data.institutionalPools;
  citizenPools = data.citizenPools;
  allPools = data.allPools;
} catch (e) {
  console.error("Failed to fetch pools", e);
}

const activePools =
  allPools?.filter(
    (p) => p.pool_statuses?.status_name?.toLowerCase() === "active",
  ) || [];
const formingPools =
  allPools?.filter(
    (p) => p.pool_statuses?.status_name?.toLowerCase() === "forming",
  ) || [];

const totalManaged =
  allPools?.reduce((acc, p) => acc + Number(p.total_payout_amount || 0), 0) || 0;
const avgContribution = allPools?.length
  ? allPools.reduce(
      (acc, p) => acc + Number(p.cycle_contribution_amount || 0),
      0,
    ) / allPools.length
  : 0;

const formatCurrency = (val: number) =>
  new Intl.NumberFormat("en-PH", { style: "currency", currency: "PHP" }).format(
    val,
  );
---

<AdminLayout
  title="CSMP - Pool Management"
  pageTitle="Pool Management"
>
  <Fragment slot="head">
    <script is:inline src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  </Fragment>
  <!-- Header Section -->
  <div class="flex justify-between items-center mb-xl">
    <div>
      <h2 class="font-display-lg text-display-lg text-primary">
        Manage Savings Pools
      </h2>
      <p class="text-on-surface-variant font-body-md text-body-md mt-1">
        Oversee institutional micro-finance cycles and member allocations.
      </p>
    </div>
    <button
      class="flex items-center gap-2 bg-primary text-on-primary px-lg py-3 rounded-xl font-title-sm text-title-sm hover:opacity-90 transition-all active:scale-95 shadow-sm"
      onclick="openCreatePoolModal()"
    >
      <span class="material-symbols-outlined">add</span>
      Create New Pool
    </button>
  </div>

  <!-- Metric Overview (Bento Style) -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-lg mb-xl">
    <div
      class="bg-white p-lg rounded-xl shadow-[0px_2px_4px_rgba(0,0,0,0.05)] border border-outline-variant/30"
    >
      <p
        class="text-on-surface-variant font-label-caps text-label-caps uppercase mb-2"
      >
        Total Managed Funds
      </p>
      <h3 class="font-display-lg text-display-lg text-primary">
        {formatCurrency(totalManaged)}
      </h3>
      <div class="flex items-center gap-1 mt-2 text-secondary">
        <span class="material-symbols-outlined text-sm">payments</span>
        <span class="text-body-sm font-body-sm">All Time</span>
      </div>
    </div>
    <div
      class="bg-white p-lg rounded-xl shadow-[0px_2px_4px_rgba(0,0,0,0.05)] border border-outline-variant/30"
    >
      <p
        class="text-on-surface-variant font-label-caps text-label-caps uppercase mb-2"
      >
        Active Cycles
      </p>
      <h3 class="font-display-lg text-display-lg text-primary">
        {activePools.length}
      </h3>
      <p class="text-on-surface-variant text-body-sm font-body-sm mt-2">
        Currently running
      </p>
    </div>
    <div
      class="bg-white p-lg rounded-xl shadow-[0px_2px_4px_rgba(0,0,0,0.05)] border border-outline-variant/30"
    >
      <p
        class="text-on-surface-variant font-label-caps text-label-caps uppercase mb-2"
      >
        Forming Pools
      </p>
      <h3 class="font-display-lg text-display-lg text-tertiary-fixed-dim">
        {formingPools.length}
      </h3>
      <p class="text-on-surface-variant text-body-sm font-body-sm mt-2">
        Recruiting members
      </p>
    </div>
    <div
      class="bg-white p-lg rounded-xl shadow-[0px_2px_4px_rgba(0,0,0,0.05)] border border-outline-variant/30 overflow-hidden relative"
    >
      <div class="relative z-10">
        <p
          class="text-on-surface-variant font-label-caps text-label-caps uppercase mb-2"
        >
          Avg. Contribution
        </p>
        <h3 class="font-display-lg text-display-lg text-primary">
          {formatCurrency(avgContribution)}
        </h3>
        <p class="text-on-surface-variant text-body-sm font-body-sm mt-2">
          Per member
        </p>
      </div>
    </div>
  </div>

  <!-- Pool Grid -->
  <div class="mb-4 mt-8 flex items-center justify-between">
    <h3 class="font-headline-md text-headline-md text-primary">Institutional Pools</h3>
    <span class="text-body-sm text-on-surface-variant bg-surface-container-low px-3 py-1 rounded-full">{institutionalPools.length} Pools</span>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-lg mb-xl">
    {
      institutionalPools &&
        institutionalPools.map((pool) => {
          const status = pool.pool_statuses?.status_name || "Unknown";
          const isForming = status.toLowerCase() === "forming";
          const isPendingApproval = status.toLowerCase() === "pending_approval" || status.toLowerCase() === "pending";
          const membersCount = pool.pool_members?.length || 0;
          const fillPercentage = Math.min(100, Math.round((membersCount / pool.max_members) * 100) || 0);
          
          let statusBadgeClass = "bg-secondary/15 text-secondary";
          if (isForming) statusBadgeClass = "bg-tertiary-fixed/30 text-tertiary-fixed-dim";
          if (isPendingApproval) statusBadgeClass = "bg-orange-100 text-orange-700";

          return (
            <div class="bg-white p-lg rounded-xl shadow-[0px_2px_4px_rgba(0,0,0,0.05)] border border-outline-variant/30 hover:border-primary/30 transition-all group">
              <div class="flex justify-between items-start mb-lg">
                <h4 class="font-headline-md text-headline-md text-primary truncate pr-2">
                  {pool.pool_name}
                </h4>
                <span class={`px-3 py-1 rounded-full font-label-caps text-label-caps uppercase flex-none ${statusBadgeClass}`}>
                  {isPendingApproval ? 'PENDING' : status.replace('_', ' ')}
                </span>
              </div>
              <div class="space-y-4">
                <div class="flex justify-between items-center text-body-md font-body-md">
                  <span class="text-on-surface-variant">Max Members</span>
                  <span class="text-primary font-semibold">{pool.max_members}</span>
                </div>
                <div class="flex justify-between items-center text-body-md font-body-md">
                  <span class="text-on-surface-variant">Contribution</span>
                  <span class="text-primary font-semibold">{formatCurrency(pool.cycle_contribution_amount)}</span>
                </div>
                <div class="w-full bg-surface-container-highest h-2 rounded-full overflow-hidden">
                  <div class={`${isForming ? "bg-tertiary-fixed-dim" : "bg-secondary"} h-full rounded-full`} style={`width: ${fillPercentage}%`} />
                </div>
                <div class="flex justify-between items-center text-body-sm font-body-sm">
                  <span class="text-on-surface-variant">{membersCount} of {pool.max_members} filled</span>
                  <span class="text-primary">{isForming ? "Recruiting" : "In Progress"}</span>
                </div>
              </div>
              <button data-pool={JSON.stringify(pool)} onclick="window.openPoolDrawer(JSON.parse(this.dataset.pool))" class="manage-details-btn w-full mt-lg py-3 rounded-lg border border-primary text-primary font-title-sm text-title-sm hover:bg-primary/5 transition-colors">
                Manage Details
              </button>
            </div>
          );
        })
    }
  </div>

  <div class="mb-4 mt-8 flex flex-col lg:flex-row lg:items-center justify-between border-t border-outline-variant/20 pt-8 gap-4">
    <div>
      <h3 class="font-headline-md text-headline-md text-primary">Citizen Pools</h3>
      <p class="text-on-surface-variant text-body-sm">Created by verified agents and citizens.</p>
    </div>
    
    <div class="flex items-center bg-surface-container-low p-1 rounded-lg overflow-x-auto">
      <button onclick="filterCitizenPools('all', this)" class="citizen-tab-btn active px-4 py-1.5 rounded-md text-sm font-medium bg-white text-primary shadow-sm transition-all whitespace-nowrap">All</button>
      <button onclick="filterCitizenPools('pending', this)" class="citizen-tab-btn px-4 py-1.5 rounded-md text-sm font-medium text-on-surface-variant hover:text-on-surface transition-all whitespace-nowrap">Pending Approval</button>
      <button onclick="filterCitizenPools('forming', this)" class="citizen-tab-btn px-4 py-1.5 rounded-md text-sm font-medium text-on-surface-variant hover:text-on-surface transition-all whitespace-nowrap">Forming</button>
      <button onclick="filterCitizenPools('active', this)" class="citizen-tab-btn px-4 py-1.5 rounded-md text-sm font-medium text-on-surface-variant hover:text-on-surface transition-all whitespace-nowrap">Active</button>
      <button onclick="filterCitizenPools('completed', this)" class="citizen-tab-btn px-4 py-1.5 rounded-md text-sm font-medium text-on-surface-variant hover:text-on-surface transition-all whitespace-nowrap">Completed</button>
      <button onclick="filterCitizenPools('cancelled', this)" class="citizen-tab-btn px-4 py-1.5 rounded-md text-sm font-medium text-on-surface-variant hover:text-on-surface transition-all whitespace-nowrap">Cancelled</button>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-lg">
    {
      citizenPools && citizenPools.length > 0 ?
        citizenPools.map((pool) => {
          const status = pool.pool_statuses?.status_name || "Unknown";
          const isForming = status.toLowerCase() === "forming";
          const isPendingApproval = status.toLowerCase() === "pending_approval" || status.toLowerCase() === "pending";
          const membersCount = pool.pool_members?.length || 0;
          const fillPercentage = Math.min(100, Math.round((membersCount / pool.max_members) * 100) || 0);
          
          const orgFirst = pool.users?.first_name || '';
          const orgLast = pool.users?.last_name || '';
          const orgName = [orgFirst, orgLast].filter(Boolean).join(' ') || 'Citizen';

          let statusBadgeClass = "bg-secondary/15 text-secondary";
          if (isForming) statusBadgeClass = "bg-tertiary-fixed/30 text-tertiary-fixed-dim";
          if (isPendingApproval) statusBadgeClass = "bg-orange-100 text-orange-700";

          return (
            <div class="citizen-pool-card bg-white p-lg rounded-xl shadow-[0px_2px_4px_rgba(0,0,0,0.05)] border border-outline-variant/30 hover:border-primary/30 transition-all group" data-status={isPendingApproval ? 'pending' : status.toLowerCase()}>
              <div class="flex justify-between items-start mb-2">
                <h4 class="font-headline-md text-headline-md text-primary truncate pr-2">
                  {pool.pool_name}
                </h4>
                <span class={`px-3 py-1 rounded-full font-label-caps text-label-caps uppercase flex-none ${statusBadgeClass}`}>
                  {isPendingApproval ? 'PENDING' : status.replace('_', ' ')}
                </span>
              </div>
              <p class="text-[11px] text-on-surface-variant mb-lg uppercase tracking-widest flex items-center gap-1">
                <span class="material-symbols-outlined text-[14px]">person</span>
                Created by {orgName}
              </p>
              <div class="space-y-4">
                <div class="flex justify-between items-center text-body-md font-body-md">
                  <span class="text-on-surface-variant">Max Members</span>
                  <span class="text-primary font-semibold">{pool.max_members}</span>
                </div>
                <div class="flex justify-between items-center text-body-md font-body-md">
                  <span class="text-on-surface-variant">Contribution</span>
                  <span class="text-primary font-semibold">{formatCurrency(pool.cycle_contribution_amount)}</span>
                </div>
                <div class="w-full bg-surface-container-highest h-2 rounded-full overflow-hidden">
                  <div class={`${isForming ? "bg-tertiary-fixed-dim" : "bg-secondary"} h-full rounded-full`} style={`width: ${fillPercentage}%`} />
                </div>
                <div class="flex justify-between items-center text-body-sm font-body-sm">
                  <span class="text-on-surface-variant">{membersCount} of {pool.max_members} filled</span>
                  <span class="text-primary">{isPendingApproval ? "Waiting for Approval" : (isForming ? "Recruiting" : "In Progress")}</span>
                </div>
              </div>
              
              <button data-pool={JSON.stringify(pool)} onclick="window.openPoolDrawer(JSON.parse(this.dataset.pool))" class="manage-details-btn w-full mt-lg py-3 rounded-lg border border-primary text-primary font-title-sm text-title-sm hover:bg-primary/5 transition-colors">
                Manage Details
              </button>
              
              {isPendingApproval && (
                <div class="flex gap-2 mt-2">
                  <button data-pool={pool.id} onclick="window.approvePool(this.dataset.pool)" class="w-1/2 py-2 rounded-lg bg-primary text-white font-title-sm text-title-sm hover:bg-primary/90 transition-colors">
                    Approve
                  </button>
                  <button data-pool={pool.id} onclick="window.rejectPool(this.dataset.pool)" class="w-1/2 py-2 rounded-lg border border-red-500 text-red-500 font-title-sm text-title-sm hover:bg-red-50 transition-colors">
                    Reject
                  </button>
                </div>
              )}
            </div>
          );
        })
      :
      <div id="citizen-empty-state" class="col-span-full py-xl text-center border-2 border-dashed border-outline-variant/50 rounded-xl bg-surface-container-low/30">
        <span class="material-symbols-outlined text-4xl text-on-surface-variant/50 mb-2">sentiment_dissatisfied</span>
        <p class="text-on-surface-variant font-body-md">No citizen pools found for this category.</p>
      </div>
    }
  </div>


  <script is:inline>
    window.filterCitizenPools = function(status, btnElement) {
      // Update active tab styling
      document.querySelectorAll('.citizen-tab-btn').forEach(btn => {
        btn.classList.remove('bg-white', 'text-primary', 'shadow-sm');
        btn.classList.add('text-on-surface-variant');
      });
      btnElement.classList.add('bg-white', 'text-primary', 'shadow-sm');
      btnElement.classList.remove('text-on-surface-variant');

      // Filter cards
      const cards = document.querySelectorAll('.citizen-pool-card');
      let visibleCount = 0;
      cards.forEach(card => {
        if (status === 'all' || card.dataset.status === status) {
          card.style.display = 'block';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });
      
      // Show/Hide empty state
      const emptyState = document.getElementById('citizen-empty-state');
      if (emptyState) {
        emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
      }
    };

    window.approvePool = function(poolId) {
       Swal.fire({
          title: 'Approve Citizen Pool?',
          text: "This pool will become FORMING and open for members to join.",
          icon: 'question',
          showCancelButton: true,
          confirmButtonColor: '#00544f',
          confirmButtonText: 'Yes, Approve'
       }).then((result) => {
          if (result.isConfirmed) {
             fetch('/api/pools/approve', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ pool_id: poolId })
             }).then(r => r.json()).then(data => {
                if (data.success) window.location.reload();
                else Swal.fire('Error', data.error, 'error');
             });
          }
       });
    };
    
    window.rejectPool = function(poolId) {
       Swal.fire({
          title: 'Reject Citizen Pool?',
          text: "This pool will be CANCELLED permanently.",
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#d33',
          confirmButtonText: 'Yes, Reject'
       }).then((result) => {
          if (result.isConfirmed) {
             fetch('/api/pools/reject', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ pool_id: poolId })
             }).then(r => r.json()).then(data => {
                if (data.success) window.location.reload();
                else Swal.fire('Error', data.error, 'error');
             });
          }
       });
    };

    window.openMemberModal = function(encodedMember) {
       const member = JSON.parse(atob(encodedMember));
       
       const firstName = member.users?.first_name || '';
       const lastName = member.users?.last_name || '';
       const fullName = [firstName, lastName].filter(Boolean).join(' ') || 'Anonymous Member';
       
       const addr = member.users?.stellar_public_key || member.users?.address || 'Unknown Address';
       const seq = member.payout_sequence_number || 'TBD';
       const contributed = new Intl.NumberFormat('en-PH', { style: 'currency', currency: 'PHP' }).format(member.total_contributed || 0);
       const role = member.users?.role || 'Member';
       
       Swal.fire({
         html: `
           <div class="text-left font-sans p-6">
             <h3 class="font-display-sm text-on-surface mb-2">${fullName}</h3>
             <p class="text-label-sm text-on-surface-variant uppercase tracking-widest mb-6 border-b border-outline-variant/30 pb-4">Member Profile</p>
             
             <div class="space-y-4">
               <div>
                 <p class="text-[11px] text-on-surface-variant uppercase tracking-widest mb-1">Stellar Wallet / Address</p>
                 <code class="block font-mono text-xs text-on-surface break-all bg-surface-container-lowest p-3 border border-outline-variant/30 rounded-md">${addr}</code>
               </div>
               
               <div class="grid grid-cols-2 gap-4">
                 <div>
                   <p class="text-[11px] text-on-surface-variant uppercase tracking-widest mb-1">Role</p>
                   <p class="font-body-md text-on-surface">${role}</p>
                 </div>
                 <div>
                   <p class="text-[11px] text-on-surface-variant uppercase tracking-widest mb-1">Payout Sequence</p>
                   <p class="font-title-lg text-primary">#${seq}</p>
                 </div>
               </div>

               <div class="pt-4 border-t border-outline-variant/30">
                 <p class="text-[11px] text-on-surface-variant uppercase tracking-widest mb-1">Total Contributed</p>
                 <p class="font-display-sm text-on-surface">${contributed}</p>
               </div>
             </div>
           </div>
         `,
         showCloseButton: true,
         showConfirmButton: false,
         width: '500px',
         padding: '0',
         customClass: {
           container: 'z-[99999]',
           popup: '!rounded-none border border-outline-variant/30 !p-0 shadow-xl',
           htmlContainer: '!m-0 !p-0',
           closeButton: '!text-on-surface-variant hover:!bg-surface-container-lowest !m-2 !p-2 !transition-colors !absolute !top-2 !right-2',
         }
       });
    };

    // Drawer Logic Replaced by SweetAlert2 Modal
    window.openPoolDrawer = function(pool) {
      try {
        const poolName = pool?.pool_name || 'Unnamed Pool';
        const poolStatus = pool?.pool_statuses?.status_name || 'Unknown';
        const totalPayout = new Intl.NumberFormat('en-PH', { style: 'currency', currency: 'PHP' }).format(pool?.total_payout_amount || 0);
        const members = pool?.pool_members || [];
        const maxMembers = pool?.max_members || 1;
        const fillPct = Math.min(100, Math.round((members.length / maxMembers) * 100) || 0);

        // Cycle & Date Calculations
        let currentCycle = 0;
        let nextPayoutStr = 'Waiting to start';
        
        if (pool?.start_date) {
           const startDate = new Date(pool.start_date);
           const now = new Date();
           const diffTime = Math.abs(now - startDate);
           const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));
           const cycleDays = pool.cycle_duration_days || 7;
           currentCycle = Math.floor(diffDays / cycleDays) + 1;
           
           const nextPayoutDate = new Date(startDate);
           nextPayoutDate.setDate(nextPayoutDate.getDate() + (currentCycle * cycleDays));
           nextPayoutStr = nextPayoutDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        }

        let membersHtml = '';
        if (members.length === 0) {
           membersHtml = `<p class="text-on-surface-variant text-body-sm text-center py-4">No members have joined yet.</p>`;
        } else {
           membersHtml = members.map((m, idx) => {
              const contributionRequired = pool?.cycle_contribution_amount || 0;
              const hasPaid = (m.total_contributed || 0) >= contributionRequired;
              const receivedPayout = (m.payout_sequence_number || 999) <= currentCycle;
              
              const firstName = m.users?.first_name || '';
              const lastName = m.users?.last_name || '';
              const fullName = [firstName, lastName].filter(Boolean).join(' ') || 'Anonymous Member';
              
              const addr = m.users?.stellar_public_key || m.users?.address || 'Anonymous';
              const shortAddr = addr.length > 10 ? `${addr.substring(0, 5)}...${addr.substring(addr.length - 4)}` : addr;
              
              const mEncoded = btoa(JSON.stringify(m));
              return `
              <div onclick="openMemberModal('${mEncoded}')" class="p-4 mb-3 border-b border-outline-variant/30 bg-surface flex items-center justify-between hover:bg-surface-container-lowest cursor-pointer transition-colors">
                <div class="flex items-center gap-4">
                   <div class="w-10 h-10 rounded-none bg-surface-container-highest text-on-surface-variant flex items-center justify-center font-title-sm">
                      ${idx + 1}
                   </div>
                   <div class="text-left">
                      <p class="font-title-sm text-on-surface tracking-tight">${fullName}</p>
                      <p class="text-label-sm text-on-surface-variant flex items-center gap-1 mt-1">
                         ${hasPaid 
                           ? '<span class="material-symbols-outlined text-primary text-[14px]">check_circle</span> Paid' 
                           : '<span class="material-symbols-outlined text-orange-400 text-[14px]">pending</span> Pending'
                         }
                      </p>
                   </div>
                </div>
                <div class="text-right flex items-center gap-3">
                   <div>
                     <p class="text-[10px] text-on-surface-variant uppercase tracking-widest mb-1 opacity-70">Payout</p>
                     <span class="px-2 py-0.5 text-[11px] font-bold ${receivedPayout ? 'text-primary border border-primary/30' : 'text-on-surface-variant border border-outline-variant/30'}">
                        ${receivedPayout ? 'RECEIVED' : 'WAITING'}
                     </span>
                   </div>
                   <span class="material-symbols-outlined text-on-surface-variant/50 text-sm">chevron_right</span>
                </div>
              </div>`;
           }).join('');
        }

        Swal.fire({
          html: `
            <div class="text-left font-sans flex flex-col h-full bg-surface">
              <!-- Minimalist Header -->
              <div class="px-8 pt-8 pb-6 pr-16 bg-surface-container-lowest border-b border-outline-variant/30 flex items-start justify-between">
                <div class="flex items-center gap-4">
                  <div class="w-12 h-12 flex items-center justify-center">
                    <img src="/logo.png" alt="Logo" class="w-full h-full object-contain" />
                  </div>
                  <div>
                    <h3 class="font-display-sm text-[22px] text-on-surface m-0 tracking-tight">${poolName}</h3>
                    <div class="flex items-center gap-2 mt-1">
                      <span class="w-2 h-2 rounded-full ${poolStatus.toLowerCase() === 'active' ? 'bg-primary' : 'bg-orange-400'}"></span>
                      <p class="text-[11px] text-on-surface-variant uppercase tracking-widest">${poolStatus}</p>
                    </div>
                  </div>
                </div>
                
                <div class="text-right mt-1">
                  <p class="text-[10px] text-on-surface-variant uppercase tracking-widest mb-1">Total Payout</p>
                  <p class="font-title-lg text-on-surface tracking-tight">${totalPayout}</p>
                </div>
              </div>

              <div class="p-8 space-y-8">
                <!-- Progress Bar Section -->
                <div>
                   <div class="flex justify-between items-center text-body-sm mb-2">
                      <span class="text-on-surface-variant uppercase text-[11px] tracking-widest">Capacity</span>
                      <span class="text-on-surface font-semibold text-sm">${members.length} / ${maxMembers}</span>
                   </div>
                   <div class="w-full bg-surface-container-highest h-1 overflow-hidden">
                      <div class="bg-primary h-full transition-all duration-700 ease-out" style="width: ${fillPct}%"></div>
                   </div>
                </div>

                <!-- Stats Grid -->
                <div class="grid grid-cols-2 gap-px bg-outline-variant/30 border border-outline-variant/30">
                  <div class="bg-surface-container-lowest p-6">
                    <p class="text-[11px] text-on-surface-variant uppercase tracking-widest mb-2 flex items-center gap-2">
                      <span class="material-symbols-outlined text-[14px]">sync</span> Cycle
                    </p>
                    <p class="font-title-lg text-on-surface tracking-tight">${currentCycle > 0 ? `Cycle ${currentCycle}` : '--'}</p>
                  </div>
                  <div class="bg-surface-container-lowest p-6">
                    <p class="text-[11px] text-on-surface-variant uppercase tracking-widest mb-2 flex items-center gap-2">
                      <span class="material-symbols-outlined text-[14px]">event</span> Next Payout
                    </p>
                    <p class="font-title-lg text-on-surface tracking-tight">${nextPayoutStr}</p>
                  </div>
                </div>
                
                <!-- Members List -->
                <div class="pt-4 border-t border-outline-variant/30">
                  <h4 class="font-title-sm text-on-surface uppercase tracking-widest mb-4 flex items-center gap-2 text-[11px]">
                    <span class="material-symbols-outlined text-on-surface-variant text-[16px]">receipt_long</span>
                    Member Tracking
                  </h4>
                  <div class="max-h-[300px] overflow-y-auto custom-scrollbar">
                    ${membersHtml}
                  </div>
                </div>
              </div>
            </div>
          `,
          showCloseButton: true,
          showConfirmButton: false,
          width: '650px',
          padding: '0',
          customClass: {
            container: 'z-[99999]',
            popup: '!rounded-none border border-outline-variant/30 !p-0 shadow-2xl',
            htmlContainer: '!m-0 !p-0',
            closeButton: '!text-on-surface-variant hover:!bg-surface-container-lowest !m-2 !p-2 !transition-colors !absolute !top-2 !right-2 z-[100]',
          }
        });
      } catch (err) {
        console.error("Error opening details:", err);
        Swal.fire({
          icon: 'error',
          title: 'Oops...',
          text: 'Something went wrong while displaying pool details.'
        });
      }
    };


    // SweetAlert2 Implementation for Pool Creation
    window.openCreatePoolModal = function () {
      Swal.fire({
        title: '<div class="flex items-center justify-center gap-3"><span class="material-symbols-outlined text-primary text-3xl">savings</span><h3 class="font-display-md text-primary m-0" style="font-size: 24px;">Configure New Pool</h3></div>',
        html: `
          <div class="text-left mt-2">
            <div class="mb-5">
              <label class="block text-label-caps font-label-caps uppercase text-on-surface-variant mb-2">Pool Name</label>
              <input id="swal-pool-name" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all text-body-lg font-body-lg bg-surface-container-lowest" placeholder="e.g. Mindanao Enterprise Group">
            </div>
            
            <div class="grid grid-cols-2 gap-4 mb-5">
              <div>
                <label class="block text-label-caps font-label-caps uppercase text-on-surface-variant mb-2">Total Payout (₱)</label>
                <input id="swal-payout" type="text" inputmode="numeric" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all text-body-lg font-body-lg bg-surface-container-lowest" placeholder="5,000">
              </div>
              <div>
                <label class="block text-label-caps font-label-caps uppercase text-on-surface-variant mb-2">Contribution (₱)</label>
                <input id="swal-contribution" type="text" inputmode="numeric" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all text-body-lg font-body-lg bg-surface-container-lowest" placeholder="200">
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-5">
              <div>
                <label class="block text-label-caps font-label-caps uppercase text-on-surface-variant mb-2">Max Members</label>
                <input id="swal-members" type="number" value="10" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all text-body-lg font-body-lg bg-surface-container-lowest">
              </div>
              <div>
                <label class="block text-label-caps font-label-caps uppercase text-on-surface-variant mb-2">Cycle Duration</label>
                <select id="swal-duration" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all text-body-lg font-body-lg bg-surface-container-lowest">
                  <option>Weekly</option>
                  <option>Bi-Weekly</option>
                  <option>Monthly</option>
                </select>
              </div>
            </div>
            
            <div class="bg-surface-container-low border border-outline-variant/30 p-5 rounded-xl mt-6 relative overflow-hidden">
              <div class="absolute right-0 top-0 opacity-5">
                <span class="material-symbols-outlined" style="font-size: 80px; transform: translate(10px, -10px);">monitoring</span>
              </div>
              <p class="font-title-sm text-primary mb-3 relative z-10 flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">auto_graph</span> Cycle Projections
              </p>
              <div class="flex justify-between items-center mb-2 relative z-10">
                <span class="text-on-surface-variant font-body-sm">Total Duration</span> 
                <strong id="swal-total-duration" class="text-title-md text-primary">10 Weeks</strong>
              </div>
              <div class="flex justify-between items-center relative z-10">
                <span class="text-on-surface-variant font-body-sm">Yield Equiv.</span> 
                <strong class="text-title-md text-tertiary-fixed-dim">4.2%</strong>
              </div>
            </div>
          </div>
        `,
        position: 'center',
        showCancelButton: true,
        confirmButtonText: 'Save & Initialize',
        cancelButtonText: 'Cancel',
        buttonsStyling: false,
        width: '540px',
        customClass: {
          popup: 'rounded-2xl p-4',
          confirmButton: 'bg-primary text-white font-title-sm px-6 py-3 rounded-xl hover:opacity-90 transition-all active:scale-95 ml-3',
          cancelButton: 'bg-surface-container-highest text-on-surface font-title-sm px-6 py-3 rounded-xl hover:bg-surface-variant transition-all active:scale-95 mr-3'
        },
        didOpen: () => {
          const payoutInput = document.getElementById('swal-payout');
          const membersInput = document.getElementById('swal-members');
          const contributionInput = document.getElementById('swal-contribution');
          const durationSelect = document.getElementById('swal-duration');
          const totalDurationDisplay = document.getElementById('swal-total-duration');

          const parseNumber = (str) => parseFloat(str.replace(/,/g, '')) || 0;
          const formatNumber = (num) => new Intl.NumberFormat('en-US', { maximumFractionDigits: 2 }).format(num);

          const formatInputWhileTyping = (e) => {
            const el = e.target;
            let pos = el.selectionStart;
            const val = el.value;
            
            // Count commas before the current cursor position
            const commasBefore = (val.substring(0, pos).match(/,/g) || []).length;
            
            // Remove everything except numbers and a single decimal point
            let clean = val.replace(/[^0-9.]/g, '');
            const parts = clean.split('.');
            if (parts.length > 2) {
               clean = parts[0] + '.' + parts.slice(1).join('');
            }
            
            let formatted = '';
            if (clean !== '') {
                const parts = clean.split('.');
                const integerPart = parseInt(parts[0] || 0, 10);
                parts[0] = new Intl.NumberFormat('en-US').format(integerPart);
                if (parts.length > 1) {
                    formatted = parts[0] + '.' + parts[1].substring(0, 2);
                } else if (clean.endsWith('.')) {
                    formatted = parts[0] + '.';
                } else {
                    formatted = parts[0];
                }
            }
            
            el.value = formatted;
            
            // Calculate new cursor position
            const commasAfter = (formatted.substring(0, pos).match(/,/g) || []).length;
            pos += (commasAfter - commasBefore);
            
            // Restore cursor
            el.setSelectionRange(pos, pos);
            
            updateCalculations(e.target);
          };

          const updateCalculations = (triggerElement = null) => {
            const payout = parseNumber(payoutInput.value);
            const members = parseInt(membersInput.value) || 1;
            const durationType = durationSelect.value;

            // Only auto-compute contribution if we are NOT currently typing inside the contribution field
            if (triggerElement !== contributionInput && payout > 0 && members > 0) {
              const contrib = payout / members;
              contributionInput.value = formatNumber(contrib);
            }

            if (durationType === 'Weekly') {
              totalDurationDisplay.textContent = `${members} Weeks`;
            } else if (durationType === 'Bi-Weekly') {
              totalDurationDisplay.textContent = `${members * 2} Weeks`;
            } else if (durationType === 'Monthly') {
              totalDurationDisplay.textContent = `${members} Months`;
            }
          };

          payoutInput.addEventListener('input', formatInputWhileTyping);
          contributionInput.addEventListener('input', formatInputWhileTyping);

          membersInput.addEventListener('input', updateCalculations);
          durationSelect.addEventListener('change', updateCalculations);
          
          updateCalculations();
        },
        showLoaderOnConfirm: true,
        allowOutsideClick: () => !Swal.isLoading(),
        preConfirm: async () => {
          const poolName = document.getElementById('swal-pool-name').value;
          const payout = parseFloat(document.getElementById('swal-payout').value.replace(/,/g, ''));
          const contribution = parseFloat(document.getElementById('swal-contribution').value.replace(/,/g, ''));
          const maxMembers = document.getElementById('swal-members').value;
          const durationType = document.getElementById('swal-duration').value;

          let cycleDays = 7;
          if (durationType === 'Bi-Weekly') cycleDays = 14;
          if (durationType === 'Monthly') cycleDays = 30;

          if (!poolName || !payout || !contribution || !maxMembers) {
            Swal.showValidationMessage('Please fill out all required fields');
            return false;
          }

          try {
            const response = await fetch('/api/pools/create', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                pool_name: poolName,
                total_payout_amount: Number(payout),
                cycle_contribution_amount: Number(contribution),
                max_members: Number(maxMembers),
                cycle_duration_days: cycleDays
              })
            });
            const data = await response.json();
            if (!response.ok) throw new Error(data.error || response.statusText);
            return data;
          } catch (error) {
            return { error: error.message };
          }
        }
      }).then((result) => {
        if (result.isConfirmed) {
          if (result.value && result.value.error) {
            Swal.fire({
              title: 'Creation Failed',
              text: result.value.error,
              icon: 'error',
              confirmButtonColor: '#00342b',
              customClass: {
                popup: 'rounded-2xl',
                confirmButton: 'rounded-lg'
              }
            });
          } else {
            Swal.fire({
              title: 'Pool Created!',
              text: 'The new institutional micro-finance pool is now forming.',
              icon: 'success',
              confirmButtonColor: '#00342b',
              customClass: {
                popup: 'rounded-2xl',
                confirmButton: 'rounded-lg'
              }
            }).then(() => {
              window.location.reload();
            });
          }
        }
      });
    };
  </script>
</AdminLayout>
