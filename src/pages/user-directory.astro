---
import AdminLayout from "../layouts/AdminLayout.astro";
import { getAdminUsers } from "../server/services/userService";

let users: any[] = [];

try {
  users = await getAdminUsers();
} catch (e) {
  console.error("Failed to fetch users", e);
}
const totalUsers = users?.length || 0;
const validScores = users?.filter(u => u.did_credit_score) || [];
const avgScore =
  validScores.length > 0
    ? Math.round(
        validScores.reduce((acc, u) => acc + (u.did_credit_score || 0), 0) /
          validScores.length,
      )
    : 0;

// Dynamic Stats
const defaultedUsers = users?.filter(u => u.did_credit_score && u.did_credit_score < 400).length || 0;
const defaultRate = totalUsers > 0 ? ((defaultedUsers / totalUsers) * 100).toFixed(2) : "0.00";

const pendingVerifications = users?.filter(u => !u.did_credit_score).length || 0;

const topTierCount = users?.filter(u => u.did_credit_score >= 700).length || 0;
const medTierCount = users?.filter(u => u.did_credit_score >= 500 && u.did_credit_score < 700).length || 0;
const atRiskCount = users?.filter(u => u.did_credit_score > 0 && u.did_credit_score < 500).length || 0;
const scoredUsersCount = topTierCount + medTierCount + atRiskCount;

const topTierPercent = scoredUsersCount > 0 ? Math.round((topTierCount / scoredUsersCount) * 100) : 0;
const medTierPercent = scoredUsersCount > 0 ? Math.round((medTierCount / scoredUsersCount) * 100) : 0;
const atRiskPercent = scoredUsersCount > 0 ? Math.round((atRiskCount / scoredUsersCount) * 100) : 0;

const recentUsers = [...users].sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime()).slice(0, 4);

const timeAgo = (dateStr: string) => {
  if (!dateStr) return "";
  const diff = Date.now() - new Date(dateStr).getTime();
  const minutes = Math.floor(diff / 60000);
  if (minutes < 60) return `${Math.max(1, minutes)} minutes ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours} hours ago`;
  const days = Math.floor(hours / 24);
  return `${days} days ago`;
}

// Pagination
const currentPage = Number(Astro.url.searchParams.get("page")) || 1;
const itemsPerPage = 10;
const totalPages = Math.max(1, Math.ceil(totalUsers / itemsPerPage));
const paginatedUsers =
  users?.slice((currentPage - 1) * itemsPerPage, currentPage * itemsPerPage) ||
  [];
---

<AdminLayout
  title="CSMP - User Directory & Credit Data"
  pageTitle="User Directory & Credit Data"
  currentPath="/user-directory"
>
  <!-- Bento Stats Row -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div
      class="bg-surface-container-lowest p-6 rounded-xl border border-surface-container-highest shadow-sm"
    >
      <p class="font-label-caps text-label-caps text-on-surface-variant mb-2">
        Total Active Users
      </p>
      <div class="flex items-end gap-2">
        <span class="font-display-lg text-display-lg text-primary"
          >{totalUsers}</span
        >
        <span
          class="flex items-center text-secondary text-body-sm font-bold pb-1"
        >
          <span class="material-symbols-outlined text-[16px]">person</span> 
        </span>
      </div>
    </div>
    <div
      class="bg-surface-container-lowest p-6 rounded-xl border border-surface-container-highest shadow-sm"
    >
      <p class="font-label-caps text-label-caps text-on-surface-variant mb-2">
        Avg. DID Score
      </p>
      <div class="flex items-end gap-2">
        <span class="font-display-lg text-display-lg text-primary"
          >{avgScore}</span
        >
        <span
          class="flex items-center text-secondary text-body-sm font-bold pb-1"
        >
          <span class="material-symbols-outlined text-[16px]">trending_up</span> {avgScore >= 700 ? "Good" : avgScore >= 500 ? "Fair" : "At Risk"}
        </span>
      </div>
    </div>
    <div
      class="bg-surface-container-lowest p-6 rounded-xl border border-surface-container-highest shadow-sm"
    >
      <p class="font-label-caps text-label-caps text-on-surface-variant mb-2">
        Portfolio Default Rate
      </p>
      <div class="flex items-end gap-2">
        <span class="font-display-lg text-display-lg text-primary">{defaultRate}%</span>
        <span
          class="flex items-center text-on-tertiary-container text-body-sm font-bold pb-1"
        >
          <span class="material-symbols-outlined text-[16px]"
            >{Number(defaultRate) > 5 ? "warning" : "check_circle"}</span
          >
        </span>
      </div>
    </div>
    <div
      class="bg-surface-container-lowest p-6 rounded-xl border border-surface-container-highest shadow-sm"
    >
      <p class="font-label-caps text-label-caps text-on-surface-variant mb-2">
        Pending Verifications
      </p>
      <div class="flex items-end gap-2">
        <span class="font-display-lg text-display-lg text-primary">{pendingVerifications}</span>
        {pendingVerifications > 0 && (
        <span
          class="flex items-center text-on-error-container text-body-sm font-bold pb-1"
        >
          <span class="material-symbols-outlined text-[16px]"
            >priority_high</span
          > Action needed
        </span>
        )}
      </div>
    </div>
  </div>

  <!-- Directory Section -->
  <div
    class="bg-surface-container-lowest rounded-xl border border-surface-container-highest shadow-sm overflow-hidden"
  >
    <!-- Search & Filter Bar -->
    <div
      class="p-gutter border-b border-surface-container-highest bg-surface-container-low flex flex-col md:flex-row gap-4 items-center justify-between"
    >
      <div class="relative w-full md:w-[400px]">
        <span
          class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline"
          >search</span
        >
        <input
          class="w-full pl-10 pr-4 py-2 bg-surface border border-outline-variant rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all font-body-md"
          placeholder="Search user by name, DID, or phone..."
          type="text"
        />
      </div>
      <div class="flex items-center gap-3 w-full md:w-auto">
        <span class="font-body-md text-on-surface-variant whitespace-nowrap"
          >Filter by:</span
        >
        <select
          class="px-4 py-2 bg-surface border border-outline-variant rounded-lg font-body-md focus:outline-none focus:border-primary appearance-none pr-10 cursor-pointer relative"
        >
          <option value="all">All Users</option>
          <option value="defaulted">Defaulted</option>
          <option value="active">Active</option>
          <option selected value="excellent">Excellent Credit</option>
        </select>
        <button
          class="bg-primary text-on-primary px-lg py-2 rounded-lg font-title-sm text-title-sm hover:opacity-90 active:scale-[0.98] transition-all"
        >
          Export CSV
        </button>
      </div>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr
            class="bg-surface-container text-on-surface-variant border-b border-surface-container-highest"
          >
            <th class="px-gutter py-4 font-title-sm text-title-sm">User Name</th
            >
            <th class="px-gutter py-4 font-title-sm text-title-sm"
              >Phone Number</th
            >
            <th class="px-gutter py-4 font-title-sm text-title-sm"
              >DID Credit Score</th
            >
            <th class="px-gutter py-4 font-title-sm text-title-sm"
              >Active Pools</th
            >
            <th class="px-gutter py-4 font-title-sm text-title-sm text-right"
              >Action</th
            >
          </tr>
        </thead>
        <tbody class="divide-y divide-surface-container-highest">
          {
            paginatedUsers.length > 0 ? (
              paginatedUsers.map((user) => {
                const initials =
                  `${user.first_name?.[0] || ""}${user.last_name?.[0] || ""}`.toUpperCase();
                const activePoolsCount =
                  user.pool_members?.filter(
                    (pm: any) =>
                      pm.pools?.pool_statuses?.status_name?.toLowerCase() ===
                      "active",
                  ).length || 0;
                const score = user.did_credit_score || 0;

                // Basic color coding for score
                let scoreClass = "bg-secondary-container/20 text-secondary";
                if (score < 500) scoreClass = "bg-error/10 text-error";
                else if (score < 700)
                  scoreClass =
                    "bg-tertiary-container/20 text-on-tertiary-container";

                return (
                  <tr class="hover:bg-primary-fixed/5 transition-colors group cursor-pointer">
                    <td class="px-gutter py-4">
                      <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-surface-container flex items-center justify-center font-bold text-primary">
                          {initials}
                        </div>
                        <div>
                          <p class="font-title-sm text-title-sm text-on-surface">
                            {user.first_name} {user.last_name}
                          </p>
                          <p class="font-body-sm text-body-sm text-on-surface-variant">
                            {user.stellar_public_key ? `${user.stellar_public_key.substring(0, 8)}...${user.stellar_public_key.substring(user.stellar_public_key.length - 4)}` : "No public key"}
                          </p>
                        </div>
                      </div>
                    </td>
                    <td class="px-gutter py-4 font-code-mono text-code-mono text-on-surface-variant">
                      {user.phone_number || "N/A"}
                    </td>
                    <td class="px-gutter py-4">
                      <span
                        class={`inline-flex items-center px-3 py-1 rounded-full font-bold text-body-sm ${scoreClass}`}
                      >
                        {score}
                      </span>
                    </td>
                    <td class="px-gutter py-4">
                      <div class="flex items-center gap-2">
                        <div class="w-6 h-6 rounded-full border border-surface bg-primary/10 flex items-center justify-center text-[10px] font-bold">
                          {activePoolsCount}
                        </div>
                        <span class="text-body-sm text-on-surface-variant">
                          Active
                        </span>
                      </div>
                    </td>
                    <td class="px-gutter py-4 text-right">
                      <a
                        class="text-primary font-title-sm text-title-sm hover:underline decoration-2 underline-offset-4"
                        href="#"
                      >
                        View Profile
                      </a>
                    </td>
                  </tr>
                );
              })
            ) : (
              <tr>
                <td
                  colspan="5"
                  class="px-gutter py-8 text-center text-on-surface-variant"
                >
                  No users found.
                </td>
              </tr>
            )
          }
        </tbody>
      </table>
    </div>
    <!-- Pagination -->
    <div
      class="p-gutter border-t border-surface-container-highest flex items-center justify-between"
    >
      <p class="font-body-sm text-body-sm text-on-surface-variant">
        Showing {totalUsers > 0 ? (currentPage - 1) * itemsPerPage + 1 : 0} to {
          Math.min(currentPage * itemsPerPage, totalUsers)
        } of {totalUsers} users
      </p>
      <div class="flex items-center gap-2">
        {
          currentPage > 1 && (
            <a
              href={`?page=${currentPage - 1}`}
              class="w-8 h-8 flex items-center justify-center rounded-lg border border-outline-variant text-on-surface-variant hover:bg-surface-container transition-colors"
            >
              <span class="material-symbols-outlined text-[20px]">
                chevron_left
              </span>
            </a>
          )
        }
        <button
          class="w-8 h-8 flex items-center justify-center rounded-lg bg-primary text-on-primary font-bold text-body-sm"
          >{currentPage}</button
        >
        {
          currentPage < totalPages && (
            <a
              href={`?page=${currentPage + 1}`}
              class="w-8 h-8 flex items-center justify-center rounded-lg border border-outline-variant text-on-surface-variant hover:bg-surface-container transition-colors"
            >
              <span class="material-symbols-outlined text-[20px]">
                chevron_right
              </span>
            </a>
          )
        }
      </div>
    </div>
  </div>

  <!-- Contextual Insights Section (Asymmetric / Glassmorphism) -->
  <div class="mt-8 grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div
      class="lg:col-span-2 relative overflow-hidden rounded-xl border border-primary/10 p-gutter bg-gradient-to-br from-primary to-primary-container text-on-primary"
    >
      <div class="relative z-10">
        <h3 class="font-headline-md text-headline-md mb-2">
          Institutional Credit Report
        </h3>
        <p class="font-body-md text-body-md opacity-80 mb-6">
          Comprehensive analysis of the current portfolio health. Decentralized
          Identity (DID) score distribution shows {topTierPercent}% in the 'Excellent'
          tier (700+).
        </p>
        <div class="grid grid-cols-3 gap-4">
          <div
            class="bg-white/10 backdrop-blur-md p-4 rounded-lg border border-white/20"
          >
            <p
              class="text-xs uppercase font-bold tracking-widest opacity-60 mb-1"
            >
              Top Tier
            </p>
            <p class="text-2xl font-bold">{topTierPercent}%</p>
          </div>
          <div
            class="bg-white/10 backdrop-blur-md p-4 rounded-lg border border-white/20"
          >
            <p
              class="text-xs uppercase font-bold tracking-widest opacity-60 mb-1"
            >
              Med Tier
            </p>
            <p class="text-2xl font-bold">{medTierPercent}%</p>
          </div>
          <div
            class="bg-white/10 backdrop-blur-md p-4 rounded-lg border border-white/20"
          >
            <p
              class="text-xs uppercase font-bold tracking-widest opacity-60 mb-1"
            >
              At Risk
            </p>
            <p class="text-2xl font-bold">{atRiskPercent}%</p>
          </div>
        </div>
      </div>
      <!-- Background Visuals -->
      <div
        class="absolute -right-20 -bottom-20 w-64 h-64 bg-secondary/20 blur-3xl rounded-full"
      >
      </div>
    </div>

    <div
      class="bg-surface-container-lowest p-gutter rounded-xl border border-surface-container-highest shadow-sm"
    >
      <h3
        class="font-title-sm text-title-sm text-primary mb-4 flex items-center gap-2"
      >
        <span class="material-symbols-outlined text-[20px]">verified_user</span>
        Recent Activity
      </h3>
      <div class="space-y-4">
        {recentUsers.map((user, index) => (
          <div class="flex gap-3">
            <div class={`mt-1 w-2 h-2 rounded-full ${index % 2 === 0 ? 'bg-secondary' : 'bg-primary'} shrink-0`}></div>
            <div>
              <p class="font-body-sm text-body-sm">
                <strong>{user.first_name} {user.last_name}</strong> joined the platform
              </p>
              <p class="text-[10px] text-on-surface-variant uppercase">
                {timeAgo(user.created_at)}
              </p>
            </div>
          </div>
        ))}
        {recentUsers.length === 0 && (
          <p class="text-body-sm text-on-surface-variant">No recent activity.</p>
        )}
      </div>
      <button
        class="w-full mt-6 py-2 text-primary font-title-sm text-title-sm border border-primary/20 rounded-lg hover:bg-primary/5 transition-colors"
      >
        View Audit Log
      </button>
    </div>
  </div>

  <script is:inline>
    // Simple micro-interaction for rows
    document.querySelectorAll("tbody tr").forEach((row) => {
      row.addEventListener("click", () => {
        if (row.querySelector("a")) {
          // Simulating a navigation feel
          row.style.opacity = "0.5";
          setTimeout(() => (row.style.opacity = "1"), 150);
        }
      });
    });
  </script>
</AdminLayout>
